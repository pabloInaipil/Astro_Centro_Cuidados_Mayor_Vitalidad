---
// src/components/ProjectGallery.astro
// Galería de actividades con lightbox — Círculo Vital
// Filtro por plan + lightbox fullscreen con navegación prev/next.
// Importa datos desde src/data/projects.ts

import { categories, projects } from '@/data/projects';

// Flatten all images with their metadata for the lightbox
const allImages = projects.flatMap((project) =>
  project.images.map((img) => ({
    ...img,
    category: project.category,
  }))
);
---

<section id="actividades" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <span
        class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]"
        style="color: var(--color-accent-600);"
      >
        Nuestras Actividades
      </span>
      <h2 class="section-title mb-4">
        Así trabajamos con tu familiar
      </h2>
      <p class="section-subtitle mx-auto">
        Cada sesión combina ejercicio, acompañamiento y cercanía humana.
        Conoce algunas de nuestras actividades.
      </p>
    </div>

    <!-- Filter tabs -->
    <div class="flex flex-wrap justify-center gap-2 mb-10 reveal" id="gallery-filters">
      {categories.map((cat) => (
        <button
          type="button"
          class={`filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all duration-200 ${cat.id === 'todos' ? 'active' : ''}`}
          data-filter={cat.id}
        >
          {cat.label}
        </button>
      ))}
    </div>

    <!-- Gallery grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6" id="gallery-grid">
      {allImages.map((img, idx) => (
        <article
          class="gallery-card group rounded-2xl overflow-hidden transition-all duration-500 cursor-pointer"
          style="background-color: var(--bg-card); border: 1px solid var(--border-subtle);"
          data-category={img.category}
          data-lightbox-index={idx}
        >
          {/* Image */}
          <div class="relative aspect-[4/3] overflow-hidden">
            <div
              class="absolute inset-0 bg-cover bg-center transition-transform duration-500 group-hover:scale-105"
              style={`background-image: url('${img.src}'); background-color: var(--color-primary-200);`}
            ></div>
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/20 transition-colors duration-300"></div>

            {/* Category badge */}
            <div class="absolute top-3 left-3">
              <span class="inline-block px-3 py-1 rounded-full text-xs font-semibold text-white" style="background-color: var(--color-primary-600);">
                {categories.find((c) => c.id === img.category)?.label || img.category}
              </span>
            </div>

            {/* Zoom icon on hover */}
            <div class="absolute inset-0 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity duration-300">
              <div class="w-12 h-12 rounded-full bg-white/20 backdrop-blur-sm flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v3m0 0v3m0-3h3m-3 0H7" />
                </svg>
              </div>
            </div>
          </div>

          {/* Card info */}
          <div class="p-5">
            <h3 class="text-base font-heading font-bold mb-1" style="color: var(--text-heading);">
              {img.title}
            </h3>
            <p class="text-sm leading-relaxed mb-2" style="color: var(--text-muted);">
              {img.description}
            </p>
            {img.location && (
              <div class="flex items-center gap-1.5 text-xs" style="color: var(--text-muted); opacity: 0.7;">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
                <span>{img.location}</span>
              </div>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- ===== LIGHTBOX MODAL ===== -->
<div id="lightbox" class="lightbox" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Visor de imágenes">
  <div class="lightbox-backdrop" id="lightbox-backdrop"></div>

  <!-- Close -->
  <button type="button" id="lightbox-close" class="lightbox-close" aria-label="Cerrar visor">
    <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
    </svg>
  </button>

  <!-- Counter -->
  <div class="lightbox-counter" id="lightbox-counter"></div>

  <!-- Prev / Next arrows -->
  <button type="button" id="lightbox-prev" class="lightbox-nav lightbox-nav-prev" aria-label="Imagen anterior">
    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button type="button" id="lightbox-next" class="lightbox-nav lightbox-nav-next" aria-label="Imagen siguiente">
    <svg width="28" height="28" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
      <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Image + Caption -->
  <div class="lightbox-content" id="lightbox-content">
    <div class="lightbox-image-wrapper">
      <img id="lightbox-img" class="lightbox-img" src="" alt="" />
    </div>
    <div class="lightbox-caption">
      <h4 class="lightbox-caption-title" id="lightbox-caption-title"></h4>
      <p class="lightbox-caption-desc" id="lightbox-caption-desc"></p>
      <span class="lightbox-caption-location" id="lightbox-caption-location"></span>
    </div>
  </div>
</div>

<!-- Pass image data to JS -->
<script is:inline define:vars={{ allImages }}>
  window.__galleryImages = allImages;
</script>

<style>
  /* ===== Filter buttons ===== */
  .filter-btn {
    color: var(--text-muted);
    background-color: transparent;
    border: 1px solid var(--border-default);
  }

  .filter-btn:hover {
    color: var(--text-heading);
    border-color: var(--color-primary-400);
  }

  .filter-btn.active {
    background-color: var(--color-primary-600);
    color: white;
    border-color: var(--color-primary-600);
  }

  .gallery-card.hidden-card {
    display: none;
  }

  /* ===== Lightbox ===== */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .lightbox.is-open {
    display: flex;
  }

  .lightbox-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .lightbox-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 10;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.5rem;
    color: white;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .lightbox-close:hover {
    background: rgba(255, 255, 255, 0.2);
  }

  .lightbox-counter {
    position: absolute;
    top: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .lightbox-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 10;
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: 0.75rem;
    color: white;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .lightbox-nav:hover {
    background: rgba(255, 255, 255, 0.25);
    border-color: rgba(255, 255, 255, 0.3);
  }

  .lightbox-nav-prev { left: 1rem; }
  .lightbox-nav-next { right: 1rem; }

  @media (min-width: 768px) {
    .lightbox-nav-prev { left: 2rem; }
    .lightbox-nav-next { right: 2rem; }
  }

  .lightbox-content {
    position: relative;
    z-index: 5;
    max-width: 90vw;
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .lightbox-image-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    max-height: 70vh;
    overflow: hidden;
  }

  .lightbox-img {
    max-width: 100%;
    max-height: 70vh;
    object-fit: contain;
    border-radius: 0.5rem;
    box-shadow: 0 8px 40px rgba(0, 0, 0, 0.5);
    transition: opacity 0.3s ease;
  }

  .lightbox-caption {
    text-align: center;
    padding: 1rem 1.5rem;
    max-width: 600px;
  }

  .lightbox-caption-title {
    color: white;
    font-size: 1.125rem;
    font-weight: 700;
    margin-bottom: 0.25rem;
  }

  .lightbox-caption-desc {
    color: rgba(255, 255, 255, 0.7);
    font-size: 0.875rem;
    line-height: 1.5;
    margin-bottom: 0.25rem;
  }

  .lightbox-caption-location {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.75rem;
  }

  body.lightbox-open {
    overflow: hidden;
  }
</style>

<script>
  // ============================================================
  // GALLERY FILTER + LIGHTBOX
  // ============================================================

  interface GalleryImage {
    src: string;
    alt: string;
    title: string;
    description: string;
    location?: string;
    category: string;
  }

  const images: GalleryImage[] = (window as any).__galleryImages || [];

  // --- FILTER ---
  const filterBtns = document.querySelectorAll<HTMLButtonElement>('.filter-btn');
  const cards = document.querySelectorAll<HTMLElement>('.gallery-card');
  let activeFilter = 'todos';

  filterBtns.forEach((btn) => {
    btn.addEventListener('click', () => {
      activeFilter = btn.dataset.filter || 'todos';

      filterBtns.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');

      cards.forEach((card) => {
        if (activeFilter === 'todos' || card.dataset.category === activeFilter) {
          card.classList.remove('hidden-card');
        } else {
          card.classList.add('hidden-card');
        }
      });
    });
  });

  // --- LIGHTBOX ---
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxBackdrop = document.getElementById('lightbox-backdrop');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxCounter = document.getElementById('lightbox-counter');
  const captionTitle = document.getElementById('lightbox-caption-title');
  const captionDesc = document.getElementById('lightbox-caption-desc');
  const captionLocation = document.getElementById('lightbox-caption-location');

  let currentIndex = 0;

  function getVisibleIndices(): number[] {
    const indices: number[] = [];
    cards.forEach((card) => {
      if (!card.classList.contains('hidden-card')) {
        const idx = parseInt(card.dataset.lightboxIndex || '0');
        indices.push(idx);
      }
    });
    return indices;
  }

  function openLightbox(index: number) {
    currentIndex = index;
    updateLightbox();
    lightbox?.classList.add('is-open');
    document.body.classList.add('lightbox-open');
  }

  function closeLightbox() {
    lightbox?.classList.remove('is-open');
    document.body.classList.remove('lightbox-open');
  }

  function updateLightbox() {
    const visibleIndices = getVisibleIndices();
    const posInVisible = visibleIndices.indexOf(currentIndex);
    const img = images[currentIndex];

    if (!img || !lightboxImg) return;

    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt;

    if (lightboxCounter) {
      lightboxCounter.textContent = `${posInVisible + 1} / ${visibleIndices.length}`;
    }

    if (captionTitle) captionTitle.textContent = img.title;
    if (captionDesc) captionDesc.textContent = img.description;
    if (captionLocation) captionLocation.textContent = img.location || '';
  }

  function navigateLightbox(direction: number) {
    const visibleIndices = getVisibleIndices();
    const posInVisible = visibleIndices.indexOf(currentIndex);
    let newPos = posInVisible + direction;

    if (newPos < 0) newPos = visibleIndices.length - 1;
    if (newPos >= visibleIndices.length) newPos = 0;

    currentIndex = visibleIndices[newPos];
    updateLightbox();
  }

  // Click on gallery cards
  cards.forEach((card) => {
    card.addEventListener('click', () => {
      const idx = parseInt(card.dataset.lightboxIndex || '0');
      openLightbox(idx);
    });
  });

  // Buttons
  lightboxClose?.addEventListener('click', closeLightbox);
  lightboxBackdrop?.addEventListener('click', closeLightbox);
  lightboxPrev?.addEventListener('click', () => navigateLightbox(-1));
  lightboxNext?.addEventListener('click', () => navigateLightbox(1));

  // Keyboard
  document.addEventListener('keydown', (e) => {
    if (!lightbox?.classList.contains('is-open')) return;
    if (e.key === 'Escape') closeLightbox();
    if (e.key === 'ArrowLeft') navigateLightbox(-1);
    if (e.key === 'ArrowRight') navigateLightbox(1);
  });

  // Touch swipe
  let touchStartX = 0;

  lightbox?.addEventListener('touchstart', (e) => {
    touchStartX = (e as TouchEvent).changedTouches[0].screenX;
  }, { passive: true });

  lightbox?.addEventListener('touchend', (e) => {
    const touchEndX = (e as TouchEvent).changedTouches[0].screenX;
    const diff = touchStartX - touchEndX;
    if (Math.abs(diff) > 50) {
      if (diff > 0) navigateLightbox(1);
      else navigateLightbox(-1);
    }
  }, { passive: true });
</script>