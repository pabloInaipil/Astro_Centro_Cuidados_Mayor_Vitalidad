---
// src/components/Testimonials.astro
// Sección de testimonios — Círculo Vital
// TODO: Reemplazar con testimonios reales de familias

const testimonials = [
  {
    name: 'María González',
    role: 'Hija de paciente',
    text: 'Desde que mi mamá comenzó con las sesiones de Plan Vitalidad, su equilibrio y ánimo han mejorado notablemente. El reporte después de cada visita me da mucha tranquilidad.',
    initials: 'MG',
  },
  {
    name: 'Carlos Muñoz',
    role: 'Hijo de paciente',
    text: 'Mi papá aprendió a usar WhatsApp y ahora hace videollamadas con sus nietos. El Plan Conectado le cambió la vida. Es otra persona.',
    initials: 'CM',
  },
  {
    name: 'Ana Reyes',
    role: 'Nieta de paciente',
    text: 'Gracias al Plan Legado pudimos digitalizar los álbumes de fotos de mi abuela y escribir sus recetas familiares. Un regalo invaluable para toda la familia.',
    initials: 'AR',
  },
];
---

<section id="testimonios" class="py-20 lg:py-28" style="background-color: var(--bg-section);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <span
        class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]"
        style="color: var(--color-accent-600);"
      >
        Testimonios
      </span>
      <h2 class="section-title mb-4">
        Lo que dicen las familias
      </h2>
      <p class="section-subtitle mx-auto">
        La tranquilidad de saber que tu familiar está en buenas manos.
      </p>
    </div>

    <!-- Testimonial Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {testimonials.map((t) => (
        <div
          class="rounded-2xl p-7 reveal"
          style="background-color: var(--bg-card); border: 1px solid var(--border-subtle);"
        >
          {/* Stars */}
          <div class="flex gap-1 mb-4">
            {[1,2,3,4,5].map(() => (
              <svg class="w-4 h-4" style="color: var(--color-accent-500);" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
              </svg>
            ))}
          </div>

          {/* Quote */}
          <p class="text-sm leading-relaxed mb-6" style="color: var(--text-body);">
            "{t.text}"
          </p>

          {/* Author */}
          <div class="flex items-center gap-3">
            <div
              class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold text-white"
              style="background-color: var(--color-primary-600);"
            >
              {t.initials}
            </div>
            <div>
              <div class="text-sm font-semibold" style="color: var(--text-heading);">{t.name}</div>
              <div class="text-xs" style="color: var(--text-muted);">{t.role}</div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
