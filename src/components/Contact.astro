---
// src/components/Contact.astro
// Formulario de contacto — Círculo Vital
// Integración Web3Forms. Layout split: formulario + info de contacto.
// GTM dataLayer events: form_submit, whatsapp_click, cta_click, phone_click.
// Datos importados desde site.ts (single source of truth).

import { site } from '@/config/site';

const serviceOptions = site.services.map((s) => s.title);
serviceOptions.push('Combinación de planes', 'Otro');

const WEB3FORMS_ACCESS_KEY = site.web3formsKey;
---

<section id="contacto" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <span
        class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]"
        style="color: var(--color-accent-600);"
      >
        Contáctanos
      </span>
      <h2 class="section-title mb-4">
        ¿Quieres saber más sobre nuestros planes?
      </h2>
      <p class="section-subtitle mx-auto">
        Cuéntanos sobre tu familiar y te orientaremos sobre el plan más adecuado.
        Respondemos en menos de 24 horas.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 lg:gap-14">

      <!-- Contact Form (3 cols) -->
      <div class="lg:col-span-3 reveal">
        <form
          class="space-y-5"
          id="contact-form"
        >
          {/* Web3Forms: access key + configuración */}
          <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
          <input type="hidden" name="subject" value={`Nueva consulta — ${site.shortName} Web`} />
          <input type="hidden" name="from_name" value={site.name} />

          {/* Honeypot anti-spam */}
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

          {/* Row: Nombre + Teléfono */}
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="nombre" class="form-label">Tu nombre *</label>
              <input
                type="text"
                id="nombre"
                name="nombre"
                required
                autocomplete="name"
                placeholder="María González"
                class="form-input"
              />
            </div>
            <div>
              <label for="telefono" class="form-label">Teléfono *</label>
              <input
                type="tel"
                id="telefono"
                name="telefono"
                required
                autocomplete="tel"
                placeholder="+56 9 1234 5678"
                class="form-input"
              />
            </div>
          </div>

          {/* Email */}
          <div>
            <label for="email" class="form-label">Correo electrónico</label>
            <input
              type="email"
              id="email"
              name="email"
              autocomplete="email"
              placeholder="maria@ejemplo.cl"
              class="form-input"
            />
          </div>

          {/* Comuna */}
          <div>
            <label for="comuna" class="form-label">Comuna donde vive el adulto mayor</label>
            <input
              type="text"
              id="comuna"
              name="comuna"
              autocomplete="address-level2"
              placeholder="Ej: Ñuñoa, Providencia"
              class="form-input"
            />
          </div>

          {/* Plan de interés */}
          <div>
            <label for="servicio" class="form-label">Plan de interés *</label>
            <select id="servicio" name="servicio" required class="form-input">
              <option value="" disabled selected>Selecciona un plan</option>
              {serviceOptions.map((opt) => (
                <option value={opt}>{opt}</option>
              ))}
            </select>
          </div>

          {/* Mensaje */}
          <div>
            <label for="mensaje" class="form-label">Cuéntanos sobre tu familiar *</label>
            <textarea
              id="mensaje"
              name="mensaje"
              required
              rows={5}
              placeholder="Edad aproximada, condición física, qué tipo de apoyo necesita, horarios preferidos..."
              class="form-input resize-y"
            ></textarea>
          </div>

          {/* Submit */}
          <div>
            <button
              type="submit"
              class="btn-primary w-full sm:w-auto px-10 py-3.5 text-base gap-2"
              id="submit-btn"
            >
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              Enviar Consulta
            </button>
          </div>

          {/* Success/Error messages */}
          <div id="form-success" class="hidden p-4 rounded-xl text-sm font-medium" style="background: var(--color-accent-100); color: var(--color-primary-800);">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              ¡Mensaje enviado! Te contactaremos pronto.
            </div>
          </div>

          <div id="form-error" class="hidden p-4 rounded-xl text-sm font-medium bg-red-50 text-red-800">
            <div class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
              Hubo un error al enviar. Intenta nuevamente o contáctanos por WhatsApp.
            </div>
          </div>
        </form>
      </div>

      <!-- Contact Info (2 cols) -->
      <div class="lg:col-span-2 reveal">
        <div class="rounded-2xl p-7 lg:p-8 h-full"
          style="background-color: var(--color-primary-950); color: var(--color-surface-300);">

          <h3 class="text-xl font-heading font-bold text-white mb-6">
            Información de Contacto
          </h3>

          <div class="space-y-6">
            <!-- Phone -->
            <a href={`tel:${site.phone}`} class="flex items-start gap-4 group">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center" style="background: var(--color-primary-800);">
                <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-400 mb-0.5">Teléfono</div>
                <div class="text-white font-semibold group-hover:text-accent-400 transition-colors">
                  {site.phoneDisplay}
                </div>
              </div>
            </a>

            <!-- WhatsApp -->
            <a href={`https://wa.me/${site.whatsapp}`} target="_blank" rel="noopener" class="flex items-start gap-4 group">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center bg-green-900/50">
                <svg class="w-5 h-5 text-green-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-400 mb-0.5">WhatsApp</div>
                <div class="text-white font-semibold group-hover:text-green-400 transition-colors">
                  Escribir por WhatsApp
                </div>
              </div>
            </a>

            <!-- Email -->
            <a href={`mailto:${site.email}`} class="flex items-start gap-4 group">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center" style="background: var(--color-primary-800);">
                <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-400 mb-0.5">Email</div>
                <div class="text-white font-semibold group-hover:text-accent-400 transition-colors">
                  {site.email}
                </div>
              </div>
            </a>

            <!-- Cobertura -->
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center" style="background: var(--color-primary-800);">
                <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-400 mb-0.5">Cobertura</div>
                <div class="text-white font-semibold">{site.address.city}</div>
              </div>
            </div>

            <!-- Horario -->
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 w-11 h-11 rounded-lg flex items-center justify-center" style="background: var(--color-primary-800);">
                <svg class="w-5 h-5 text-accent-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
              </div>
              <div>
                <div class="text-xs text-surface-400 mb-0.5">Horario</div>
                <div class="text-white font-semibold">{site.businessHours.days}</div>
                <div class="text-surface-300 text-sm">{site.businessHours.hours}</div>
              </div>
            </div>
          </div>

          <!-- Trust badge -->
          <div class="mt-8 pt-6 border-t border-surface-800">
            <div class="flex items-center gap-3">
              <svg class="w-8 h-8 text-accent-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
              <div>
                <p class="text-white text-sm font-semibold">Enfoque Pedagógico</p>
                <p class="text-surface-400 text-xs">
                  Profesor de Educación Física especializado en bienestar del adulto mayor
                </p>
              </div>
            </div>
          </div>

          <!-- WhatsApp CTA -->
          <a
            href={`https://wa.me/${site.whatsapp}?text=${encodeURIComponent(site.whatsappMessage)}`}
            target="_blank"
            rel="noopener"
            class="mt-6 w-full inline-flex items-center justify-center gap-2 bg-green-600 hover:bg-green-700 text-white font-semibold py-3 px-6 rounded-xl transition-colors duration-200"
            data-gtm="whatsapp-contact"
            data-gtm-label="WhatsApp Contacto"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            </svg>
            Escribir por WhatsApp
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // ============================================================
  // FORM SUBMISSION — Web3Forms API
  // ============================================================
  declare global {
    interface Window {
      dataLayer: Record<string, unknown>[];
    }
  }

  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success');
  const errorMsg = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    successMsg?.classList.add('hidden');
    errorMsg?.classList.add('hidden');

    const originalText = submitBtn.innerHTML;
    submitBtn.disabled = true;
    submitBtn.innerHTML = `
      <svg class="animate-spin w-5 h-5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
      </svg>
      Enviando...
    `;

    try {
      const formData = new FormData(form);
      const object: Record<string, string> = {};
      formData.forEach((value, key) => {
        object[key] = value.toString();
      });

      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(object),
      });

      const result = await response.json();

      if (result.success) {
        // GTM: push evento ANTES del redirect para que GTM lo registre
        window.dataLayer = window.dataLayer || [];
        window.dataLayer.push({
          event: 'form_submit',
          form_name: 'consulta',
          form_service: object['servicio'] || '',
        });

        // Redirect a página de gracias (conversión Google Ads)
        window.location.href = '/gracias/';
        return;
      } else {
        throw new Error(result.message || 'Form submission failed');
      }
    } catch (error) {
      errorMsg?.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = originalText;
    }
  });

  // ============================================================
  // GTM TRACKING — WhatsApp, CTA, Teléfono
  // ============================================================

  // GTM: tracking clicks en WhatsApp (todos los links wa.me)
  document.querySelectorAll('a[href*="wa.me"]').forEach((link) => {
    link.addEventListener('click', () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'whatsapp_click',
        link_url: link.getAttribute('href'),
      });
    });
  });

  // GTM: tracking click en CTAs
  document.querySelectorAll('a[href="#contacto"]').forEach((link) => {
    link.addEventListener('click', () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'cta_click',
        cta_text: link.textContent?.trim() || '',
      });
    });
  });

  // GTM: tracking llamadas telefónicas
  document.querySelectorAll('a[href^="tel:"]').forEach((link) => {
    link.addEventListener('click', () => {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({
        event: 'phone_click',
        phone_number: link.getAttribute('href'),
      });
    });
  });
</script>
