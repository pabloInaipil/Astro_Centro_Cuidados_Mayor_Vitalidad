---
// src/components/Process.astro
// Sección "Cómo Funciona" — Círculo Vital
// 4 pasos del proceso de acompañamiento.
// Datos importados desde site.ts (process array)

import { site } from '@/config/site';

const iconMap: Record<string, string> = {
  'clipboard-check': 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4',
  'calendar': 'M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z',
  'home': 'M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6',
  'message-circle': 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
};
---

<section id="proceso" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <span
        class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]"
        style="color: var(--color-accent-600);"
      >
        Paso a Paso
      </span>
      <h2 class="section-title mb-4">
        ¿Cómo Funciona?
      </h2>
      <p class="section-subtitle mx-auto">
        Un proceso simple y humano para que tu familiar reciba el mejor acompañamiento.
      </p>
    </div>

    <!-- Steps -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">
      {site.process.map((step) => (
        <div class="process-step reveal text-center">
          {/* Step Number + Icon */}
          <div class="process-step__icon-wrapper">
            <span class="process-step__number">{step.step}</span>
            <div class="process-step__icon">
              <svg
                class="w-7 h-7"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="1.5"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={iconMap[step.icon] || iconMap['clipboard-check']}
                />
              </svg>
            </div>
          </div>

          <h3 class="text-lg font-heading font-bold mb-2" style="color: var(--text-heading);">
            {step.title}
          </h3>

          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            {step.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .process-step__icon-wrapper {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4.5rem;
    height: 4.5rem;
    margin-bottom: 1.25rem;
  }

  .process-step__number {
    position: absolute;
    top: -0.25rem;
    right: -0.25rem;
    width: 1.5rem;
    height: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.75rem;
    font-weight: 700;
    color: #FFFFFF;
    background-color: var(--color-accent-500);
    border-radius: 9999px;
    z-index: 1;
  }

  .process-step__icon {
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 1rem;
    background-color: var(--color-primary-50);
    color: var(--color-primary-600);
    transition: all 0.2s ease;
  }

  .process-step:hover .process-step__icon {
    background-color: var(--color-primary-600);
    color: #FFFFFF;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(42, 126, 64, 0.25);
  }

  :global(.dark) .process-step__icon,
  :global([data-theme="dark"]) .process-step__icon {
    background-color: rgba(42, 126, 64, 0.15);
    color: var(--color-primary-400);
  }

  :global(.dark) .process-step:hover .process-step__icon,
  :global([data-theme="dark"]) .process-step:hover .process-step__icon {
    background-color: var(--color-primary-600);
    color: #FFFFFF;
  }
</style>
