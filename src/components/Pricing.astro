---
// src/components/Pricing.astro
// Sección de precios — Círculo Vital
// Datos importados desde site.ts (pricing array)

import { site } from '@/config/site';
---

<section id="precios" class="py-20 lg:py-28" style="background-color: var(--bg-section);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">

    <!-- Header -->
    <div class="text-center mb-14 reveal">
      <span
        class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]"
        style="color: var(--color-accent-600);"
      >
        Inversión
      </span>
      <h2 class="section-title mb-4">
        Planes y Precios
      </h2>
      <p class="section-subtitle mx-auto">
        Elige el plan que mejor se adapte a las necesidades de tu familiar. Todos incluyen reporte post-sesión.
      </p>
    </div>

    <!-- Pricing Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {site.pricing.map((plan) => (
        <div
          class:list={[
            'pricing-card reveal rounded-2xl p-7 lg:p-8 flex flex-col',
            plan.highlighted
              ? 'pricing-card--highlighted'
              : 'pricing-card--default',
          ]}
        >
          {/* Badge para plan destacado */}
          {plan.highlighted && (
            <div class="pricing-badge">
              Más Popular
            </div>
          )}

          <h3 class="text-xl font-heading font-bold mb-2 pricing-card__title">
            {plan.name}
          </h3>

          <div class="mb-3">
            <span class="text-3xl lg:text-4xl font-heading font-bold pricing-card__price">
              {plan.price}
            </span>
          </div>

          <p class="text-sm mb-6 pricing-card__description">
            {plan.description}
          </p>

          <ul class="space-y-3 mb-8 flex-1">
            {plan.features.map((feature) => (
              <li class="flex items-start gap-2.5 text-sm pricing-card__feature">
                <svg
                  class="w-5 h-5 flex-shrink-0 mt-0.5 pricing-card__check"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2.5"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
                {feature}
              </li>
            ))}
          </ul>

          <a
            href="#contacto"
            class:list={[
              'w-full text-center py-3 px-6 rounded-xl font-semibold transition-all duration-200',
              plan.highlighted ? 'btn-primary' : 'btn-secondary',
            ]}
          >
            {plan.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Note -->
    <p class="text-center text-sm mt-8 reveal" style="color: var(--text-muted);">
      * Precios válidos para la marcha blanca. Cobertura en Ñuñoa y Providencia.
    </p>
  </div>
</section>

<style>
  .pricing-card--default {
    background-color: var(--bg-card);
    border: 1px solid var(--border-default);
  }

  .pricing-card--highlighted {
    background-color: var(--color-primary-600);
    color: #FFFFFF;
    position: relative;
    box-shadow: 0 8px 30px rgba(42, 126, 64, 0.25);
    transform: scale(1.02);
  }

  .pricing-badge {
    position: absolute;
    top: -0.75rem;
    left: 50%;
    transform: translateX(-50%);
    background-color: var(--color-accent-500);
    color: #FFFFFF;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 0.25rem 1rem;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    white-space: nowrap;
  }

  /* Default card text colors */
  .pricing-card--default .pricing-card__title {
    color: var(--text-heading);
  }

  .pricing-card--default .pricing-card__price {
    color: var(--color-primary-600);
  }

  .pricing-card--default .pricing-card__description {
    color: var(--text-muted);
  }

  .pricing-card--default .pricing-card__feature {
    color: var(--text-body);
  }

  .pricing-card--default .pricing-card__check {
    color: var(--color-primary-500);
  }

  /* Highlighted card text colors */
  .pricing-card--highlighted .pricing-card__title {
    color: #FFFFFF;
  }

  .pricing-card--highlighted .pricing-card__price {
    color: var(--color-accent-300);
  }

  .pricing-card--highlighted .pricing-card__description {
    color: var(--color-primary-100);
  }

  .pricing-card--highlighted .pricing-card__feature {
    color: var(--color-primary-100);
  }

  .pricing-card--highlighted .pricing-card__check {
    color: var(--color-accent-400);
  }

  .pricing-card--highlighted .btn-primary {
    background-color: #FFFFFF;
    color: var(--color-primary-700);
    border-color: #FFFFFF;
  }

  .pricing-card--highlighted .btn-primary:hover {
    background-color: var(--color-primary-50);
    box-shadow: 0 4px 12px rgba(255, 255, 255, 0.3);
  }

  @media (max-width: 768px) {
    .pricing-card--highlighted {
      transform: scale(1);
    }
  }
</style>
