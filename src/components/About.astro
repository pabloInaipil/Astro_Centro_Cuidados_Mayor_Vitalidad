---
// src/components/About.astro
// Sección "Sobre Nosotros" — Círculo Vital

import { site } from '@/config/site';
---

<section id="nosotros" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Imagen / Visual -->
      <div class="reveal">
        <div class="relative rounded-2xl overflow-hidden aspect-[4/3]"
          style="background-image: url('/hero/slide-01.webp'); background-size: cover; background-position: center; background-color: var(--color-primary-200);">
          <div class="absolute inset-0" style="background: linear-gradient(to top, rgba(13,40,20,0.6) 0%, transparent 60%);"></div>
          <div class="absolute bottom-6 left-6 right-6">
            <span class="inline-block px-4 py-1.5 rounded-full text-xs font-semibold text-white" style="background-color: var(--color-accent-500);">
              Profesor de Educación Física
            </span>
          </div>
        </div>
      </div>

      <!-- Contenido -->
      <div class="reveal">
        <span class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-accent-600);">
          Sobre Nosotros
        </span>
        <h2 class="section-title mb-6">
          Especialistas en bienestar del adulto mayor
        </h2>
        <p class="text-base leading-relaxed mb-5" style="color: var(--text-body);">
          Somos un equipo liderado por un Profesor de Educación Física especializado en el bienestar
          de la persona mayor. Nuestro objetivo es que las personas de la tercera edad mantengan su
          autonomía, seguridad y alegría a través de un programa que combina el movimiento guiado,
          la estimulación mental y el apoyo tecnológico.
        </p>
        <p class="text-base leading-relaxed mb-8" style="color: var(--text-body);">
          Todo en la comodidad de su hogar, con un enfoque pedagógico que adapta cada actividad
          a las capacidades reales de la persona, fomentando el aprendizaje y la confianza.
        </p>

        <!-- Trust features -->
        <div class="space-y-4">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-primary-100);">
              <svg class="w-5 h-5" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold" style="color: var(--text-heading);">Enfoque Pedagógico</h4>
              <p class="text-sm" style="color: var(--text-muted);">Cada ejercicio adaptado a las capacidades reales de la persona.</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-primary-100);">
              <svg class="w-5 h-5" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold" style="color: var(--text-heading);">Reporte a la Familia</h4>
              <p class="text-sm" style="color: var(--text-muted);">Informe detallado por WhatsApp después de cada sesión.</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-primary-100);">
              <svg class="w-5 h-5" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold" style="color: var(--text-heading);">Cercanía de Barrio</h4>
              <p class="text-sm" style="color: var(--text-muted);">Conocemos la vida de barrio en Ñuñoa y Providencia.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
