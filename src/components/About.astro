---
// src/components/About.astro
// Sección "Sobre Nosotros" — Círculo Vital
// Estructura split: imagen + contenido con features (estilo TodoCasa)

import { site } from '@/config/site';
---

<section id="nosotros" class="py-20 lg:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Imagen + Badge -->
      <div class="reveal">
        <div class="relative">
          <div class="rounded-2xl overflow-hidden aspect-[4/3]"
            style="background-image: url('/hero/karin.png'); background-size: cover; background-position: center; background-color: var(--color-primary-200);">
          </div>

          <!-- Badge flotante -->
          <div class="absolute -bottom-5 -right-3 sm:right-6 rounded-xl px-5 py-4 shadow-lg"
            style="background-color: var(--color-primary-600);">
            <div class="text-center">
              <div class="text-2xl sm:text-3xl font-heading font-extrabold text-white leading-none">
                30+
              </div>
              <div class="text-xs sm:text-sm font-medium mt-0.5" style="color: var(--color-primary-100);">
                Años en el<br/>deporte
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contenido -->
      <div class="reveal">
        <span class="inline-block mb-3 text-xs font-semibold uppercase tracking-[0.2em]" style="color: var(--color-accent-600);">
          Sobre Nosotros
        </span>
        <h2 class="section-title mb-6">
          Del alto rendimiento al cuidado integral del adulto mayor
        </h2>

        <p class="text-base leading-relaxed mb-4" style="color: var(--text-body);">
          <strong>{site.shortName}</strong> nace de la convicción de que el movimiento transforma vidas en
          cualquier etapa. Su fundadora, <strong>Karin Reinhardt</strong>, es Profesora de Educación Física,
          ex seleccionada nacional y <strong>campeona mundial de hockey patines</strong> con la selección chilena
          en 2006. Pionera en la creación de la rama femenina de la disciplina en Chile, dedicó más de dos décadas
          a la competición de alto nivel antes de volcarse a un nuevo propósito.
        </p>

        <p class="text-base leading-relaxed mb-8" style="color: var(--text-body);">
          Tras retirarse de la competitividad en 2013 y años de trabajo en programas deportivos comunitarios,
          hoy canaliza toda esa experiencia en el bienestar de las personas mayores: ejercicio adaptado, estimulación
          cognitiva y acompañamiento integral, llevando la disciplina y calidez del deporte directamente al hogar
          de quienes más lo necesitan.
        </p>

        <!-- Features grid 2x2 -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-primary-100);">
              <svg class="w-5 h-5" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold" style="color: var(--text-heading);">Trayectoria Comprobada</h4>
              <p class="text-sm" style="color: var(--text-muted);">Campeona mundial y pionera del hockey patines femenino en Chile.</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-primary-100);">
              <svg class="w-5 h-5" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold" style="color: var(--text-heading);">Enfoque Pedagógico</h4>
              <p class="text-sm" style="color: var(--text-muted);">Cada ejercicio adaptado a las capacidades reales de la persona.</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-primary-100);">
              <svg class="w-5 h-5" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold" style="color: var(--text-heading);">Reporte a la Familia</h4>
              <p class="text-sm" style="color: var(--text-muted);">Informe detallado por WhatsApp después de cada sesión.</p>
            </div>
          </div>

          <div class="flex items-start gap-3">
            <div class="flex-shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background-color: var(--color-primary-100);">
              <svg class="w-5 h-5" style="color: var(--color-primary-600);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <div>
              <h4 class="text-sm font-bold" style="color: var(--text-heading);">Cercanía de Barrio</h4>
              <p class="text-sm" style="color: var(--text-muted);">Atención a domicilio en Ñuñoa y Providencia.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
