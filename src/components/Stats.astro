---
// src/components/Stats.astro
// Sección de estadísticas/highlights — Círculo Vital
// Diseño de cards con valores destacados (texto, no solo numéricos).
// Datos importados desde site.ts (single source of truth).

import { site } from '@/config/site';
---

<section class="py-16 lg:py-20" style="background-color: var(--color-primary-600);">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-10" id="stats-grid">
      {site.stats.map((stat) => (
        <div class="stat-item text-center reveal">
          <div class="stat-value">
            {stat.value}
          </div>
          <div class="stat-label">
            {stat.label}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stat-value {
    font-family: 'Plus Jakarta Sans', 'Inter', system-ui, sans-serif;
    font-size: clamp(1.75rem, 5vw, 3.5rem);
    font-weight: 800;
    color: #FFFFFF;
    line-height: 1.1;
    margin-bottom: 0.25rem;
  }

  .stat-label {
    font-size: clamp(0.8rem, 1.5vw, 1rem);
    font-weight: 500;
    color: var(--color-primary-100);
    opacity: 0.85;
  }

  /* Reveal animation for stats */
  .stat-item {
    opacity: 0;
    transform: translateY(16px);
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  .stat-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Stagger effect */
  .stat-item:nth-child(1) { transition-delay: 0ms; }
  .stat-item:nth-child(2) { transition-delay: 100ms; }
  .stat-item:nth-child(3) { transition-delay: 200ms; }
  .stat-item:nth-child(4) { transition-delay: 300ms; }
</style>

<script>
  // IntersectionObserver for stat items reveal
  const statItems = document.querySelectorAll('.stat-item');

  if (statItems.length > 0) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            // Reveal all stat items when grid enters viewport
            statItems.forEach((item) => item.classList.add('is-visible'));
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.3 }
    );

    const grid = document.getElementById('stats-grid');
    if (grid) observer.observe(grid);
  }
</script>
