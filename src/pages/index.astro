---
// src/pages/index.astro
// Página principal — Círculo Vital
// Composición de todas las secciones de la landing page.

import Layout from '@layouts/Layout.astro';
import Hero from '@components/Hero.astro';
import Stats from '@components/Stats.astro';
import Services from '@components/Services.astro';
import Process from '@components/Process.astro';
import ProjectGallery from '@components/ProjectGallery.astro';
import About from '@components/About.astro';
import Pricing from '@components/Pricing.astro';
// Testimonials oculto hasta contar con testimonios reales de familias.
// import Testimonials from '@components/Testimonials.astro';
import CtaBanner from '@components/CtaBanner.astro';
import Contact from '@components/Contact.astro';
import { site } from '@/config/site';
---

<Layout>
  {/* H1 semántico de la página (accesible, sin impacto visual) */}
  <h1 class="sr-only">{site.name} — {site.tagline}. Cobertura en Ñuñoa y Providencia, Santiago.</h1>
  <Hero />
  <Stats />
  <Services />
  <Process />
  <ProjectGallery />
  <About />
  <Pricing />
  <CtaBanner />
  <Contact />
</Layout>
